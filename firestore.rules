rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "glitchxkartik@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Subscribers collection
    match /subscribers/{subscriberId} {
      allow create: if isValidSubscriber(incoming());
      allow read, list: if isAdmin();
      
      function isValidSubscriber(data) {
        return data.keys().hasAll(['email', 'createdAt']) 
          && data.keys().size() == 2
          && data.email is string && data.email.size() <= 256
          && data.createdAt == request.time;
      }
    }

    // Contacts collection
    match /contacts/{contactId} {
      allow create: if isValidContact(incoming());
      allow read, list: if isAdmin();

      function isValidContact(data) {
        return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
          && data.keys().size() == 4
          && data.name is string && data.name.size() <= 100
          && data.email is string && data.email.size() <= 256
          && data.message is string && data.message.size() <= 5000
          && data.createdAt == request.time;
      }
    }

    // Articles collection
    match /articles/{articleId} {
      allow read, list: if true;
      allow create: if isAdmin() && isValidArticle(incoming());
      allow update: if isAdmin() && isValidArticle(incoming());
      allow delete: if isAdmin();

      function isValidArticle(data) {
        return data.keys().hasAll(['title', 'summary', 'image', 'category', 'readTime', 'createdAt'])
          && data.title is string && data.title.size() <= 200
          && data.summary is string && data.summary.size() <= 1000
          && data.image is string && data.image.size() <= 1000
          && data.category is string && data.category.size() <= 50
          && data.readTime is string && data.readTime.size() <= 20;
      }
    }

    // Admins collection
    match /admins/{adminId} {
      // Allow the first admin (the user) to be identified
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
